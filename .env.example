# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# --- Database (Prisma) ---
# Use the connection-pooled URL for runtime, direct URL for migrations
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Performance / profiling (temporary) ---
# PROFILE_API=1         # route segment logs in selected API handlers
# PROFILE_PHASE2=1      # deep [PROFILE] logs on phase-2 target routes
# AUTH_PROFILE=1        # auth timing + duplicate getUser() evidence
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STORAGE_BUCKET=friendintro

# Demo seed (npm run seed:demo) requires Supabase service role + database URL above.

# --- Admin ---
# Comma-separated list of admin emails (automatic admin access)
ADMIN_EMAILS=anesugozo@gmail.com

# Legal (fill before production)
LEGAL_ENTITY_NAME="[INSERT LEGAL ENTITY NAME]"
LEGAL_ENTITY_ADDRESS="[INSERT COMPANY ADDRESS]"
LEGAL_SUPPORT_EMAIL="[INSERT SUPPORT EMAIL]"
LEGAL_PRIVACY_VERSION=2026-05-24
LEGAL_TERMS_VERSION=2026-05-24
LEGAL_COOKIES_VERSION=2026-05-24
# Primary: Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM="FriendIntro <invites@yourdomain.com>"

# Fallback: SMTP (optional — used when RESEND_API_KEY is unset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Web Push (VAPID) ---
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@friendintro.app

# Phone verification (Twilio SMS — optional; use beta code for local testing)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PHONE_VERIFICATION_BETA_CODE=123456

# --- Production deploy (npm run deploy / rollback / doctor) ---
# SSH public-key auth only — passwords are never used
DEPLOY_SSH_HOST=your-server.interserver.net
DEPLOY_SSH_USER=your-cpanel-user
DEPLOY_SSH_KEY=C:/Users/you/.ssh/id_ed25519
DEPLOY_SSH_PORT=22
DEPLOY_APP_PATH=~/buddyintro
DEPLOY_GIT_BRANCH=main
# Optional: pin deploy to a specific commit SHA instead of tracking origin/main
# DEPLOY_COMMIT_SHA=abc123def456...
# DEPLOY_GIT_REPO_URL=https://github.com/owner/buddyintro.git
DEPLOY_HEALTH_URL=https://buddyintro.com/api/health
DEPLOY_PASSENGER_WAIT_MS=15000
DEPLOY_HEALTH_POLL_MS=5000
DEPLOY_HEALTH_MAX_MS=120000
# Node.js bin directory on the deployment server (leave blank for auto-detect on standard Linux)
DEPLOY_NODE_BIN=
# CloudLinux / InterServer / cPanel — set explicitly for deterministic resolution:
# DEPLOY_NODE_BIN=/opt/alt/alt-nodejs20/root/usr/bin
# DEPLOY_NODE_MIN=>=18.17.0
# GITHUB_REPOSITORY=owner/buddyintro
